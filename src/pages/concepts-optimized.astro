---
import Layout from '../layouts/Layout.astro';
import ConceptsHeader from '../components/ConceptsHeader.astro';
import ConceptsShowcase from '../components/ConceptsShowcase.astro';
---

<Layout title="Concepts - Netspire (Optimized)" description="Explore our collection of high-converting website designs built for different industries. Each concept is optimized for maximum conversions and user engagement.">
  <!-- Page Transition Overlay -->
  <div class="page-transition-overlay" id="pageTransition">
    <div class="transition-background"></div>
  </div>

  <!-- Optimized Header Component -->
  <ConceptsHeader />
  
  <!-- Optimized Showcase Component -->
  <ConceptsShowcase />

  <!-- Conversion Importance Section -->
  <section class="conversion-importance">
    <div class="conversion-container">
      <div class="conversion-header">
        <h2 class="conversion-title">Why Conversion Optimization Matters</h2>
        <p class="conversion-subtitle">Small changes in design can lead to massive improvements in business results</p>
      </div>
      
      <div class="conversion-points">
        <div class="conversion-point">
          <div class="point-icon">📈</div>
          <h3>Revenue Growth</h3>
          <p>Average 340% increase in revenue through optimized user journeys and strategic CTA placement</p>
        </div>
        
        <div class="conversion-point">
          <div class="point-icon">⚡</div>
          <h3>Faster Load Times</h3>
          <p>Sub-2 second loading speeds using advanced optimization techniques and modern frameworks</p>
        </div>
        
        <div class="conversion-point">
          <div class="point-icon">🎯</div>
          <h3>User Experience</h3>
          <p>Intuitive interfaces that guide users naturally towards conversion actions</p>
        </div>
        
        <div class="conversion-point">
          <div class="point-icon">📱</div>
          <h3>Mobile First</h3>
          <p>Responsive designs optimized for mobile conversion with touch-friendly interactions</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pre-Footer CTA Section -->
  <section class="pre-footer-cta">
    <div class="pre-footer-container">
      <div class="pre-footer-content">
        <div class="cta-main">
          <h2 class="cta-title">Ready to Transform Your Business?</h2>
          <p class="cta-description">Join hundreds of companies that have revolutionized their digital presence with our conversion-optimized designs.</p>
          <div class="cta-action">
            <a href="#contact" class="cta-primary-btn">
              <span>Start Your Project</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#contact" class="cta-secondary-btn">
              <span>Schedule Consultation</span>
            </a>
          </div>
        </div>
        <div class="cta-stats">
          <div class="stat-item">
            <div class="stat-number">250%</div>
            <div class="stat-label">Avg. Conversion Increase</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">48hrs</div>
            <div class="stat-label">First Draft Delivery</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Client Satisfaction</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Optimized CSS - Only essential styles */
  
  /* Page Transition */
  .page-transition-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .transition-background {
    width: 100%;
    height: 100%;
    background: #000000;
  }

  /* Conversion Importance Section */
  .conversion-importance {
    background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
    padding: 120px 0;
  }

  .conversion-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .conversion-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .conversion-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #000000;
    line-height: 1.2;
    margin: 0 0 20px 0;
  }

  .conversion-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    color: #666666;
    margin: 0;
    max-width: 600px;
    margin: 0 auto;
  }

  .conversion-points {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
  }

  .conversion-point {
    text-align: center;
    padding: 40px 30px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease;
    opacity: 0;
    transform: translateY(30px);
  }

  .conversion-point:hover {
    transform: translateY(-5px);
  }

  .point-icon {
    font-size: 3rem;
    margin-bottom: 20px;
    display: block;
  }

  .conversion-point h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: #000000;
    margin: 0 0 15px 0;
  }

  .conversion-point p {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #666666;
    margin: 0;
  }

  /* Pre-Footer CTA Section */
  .pre-footer-cta {
    background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
    padding: 100px 0;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }

  .pre-footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .pre-footer-content {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .cta-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #000000;
    line-height: 1.1;
    margin: 0 0 24px 0;
  }

  .cta-description {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    line-height: 1.6;
    color: #666666;
    margin: 0 0 40px 0;
  }

  .cta-action {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .cta-primary-btn,
  .cta-secondary-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    text-decoration: none;
    border-radius: 50px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .cta-primary-btn {
    background: #000000;
    color: white;
    border: 2px solid #000000;
  }

  .cta-primary-btn:hover {
    background: transparent;
    color: #000000;
    transform: translateY(-2px);
  }

  .cta-secondary-btn {
    background: transparent;
    color: #000000;
    border: 2px solid rgba(0, 0, 0, 0.2);
  }

  .cta-secondary-btn:hover {
    border-color: #000000;
    background: #000000;
    color: white;
    transform: translateY(-2px);
  }

  .cta-stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .stat-item {
    text-align: center;
    padding: 30px 20px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease;
  }

  .stat-item:hover {
    transform: translateY(-5px);
  }

  .stat-number {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #000000;
    display: block;
    margin-bottom: 8px;
  }

  .stat-label {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #666666;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .conversion-importance,
    .pre-footer-cta {
      padding: 80px 0;
    }

    .conversion-container,
    .pre-footer-container {
      padding: 0 30px;
    }

    .conversion-points {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .pre-footer-content {
      grid-template-columns: 1fr;
      gap: 60px;
      text-align: center;
    }

    .cta-action {
      justify-content: center;
      flex-direction: column;
      align-items: center;
    }

    .cta-primary-btn,
    .cta-secondary-btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }

    .cta-stats {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  @media (max-width: 480px) {
    .conversion-container,
    .pre-footer-container {
      padding: 0 20px;
    }

    .cta-stats {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Lightweight animations - Performance optimized
  function initOptimizedAnimations() {
    console.log('🎯 Initializing optimized concepts animations...');

    // Conversion points animation using IntersectionObserver
    const observerOptions = {
      threshold: 0.2,
      rootMargin: '0px 0px -50px 0px'
    };

    const pointsObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            const element = entry.target as HTMLElement;
            element.style.opacity = '1';
            element.style.transform = 'translateY(0)';
            element.style.transition = 'all 0.8s ease';
          }, index * 150);
          pointsObserver.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Observe conversion points
    document.querySelectorAll('.conversion-point').forEach(point => {
      pointsObserver.observe(point);
    });

    console.log('✅ Optimized concepts animations ready');
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initOptimizedAnimations);
  } else {
    initOptimizedAnimations();
  }
</script> 