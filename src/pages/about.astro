<script>
  function initAboutPage() {
    console.log('🎨 Initializing About page with advanced animations...');

    // Wait for GSAP to be ready
    function waitForGSAP() {
      return new Promise((resolve) => {
        if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
          resolve(true);
        } else {
          let attempts = 0;
          const maxAttempts = 30;
          
          const checkGSAP = () => {
            attempts++;
            if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
              resolve(true);
            } else if (attempts >= maxAttempts) {
              console.log('⚠️ GSAP not available, using fallback animations');
              resolve(false);
            } else {
              setTimeout(checkGSAP, 100);
            }
          };
          
          checkGSAP();
        }
      });
    }

    function initAdvancedGSAPAnimations() {
      console.log('✅ Initializing advanced GSAP about page animations');
      
      gsap.registerPlugin(ScrollTrigger);

      // Hero section entrance animation
      const heroTl = gsap.timeline({ delay: 0.5 });
      
      heroTl
        .to('.hero-badge', {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power3.out'
        })
        .to('.title-word', {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: 'power3.out',
          stagger: 0.1
        }, '-=0.4')
        .to('.hero-description', {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: 'power3.out'
        }, '-=0.6');

      // Story section animations
      ScrollTrigger.create({
        trigger: '.about-story',
        start: 'top 80%',
        onEnter: () => {
          const storyTl = gsap.timeline();
          
          storyTl
            .to('.story-header .section-number', {
              opacity: 1,
              x: 0,
              duration: 0.6,
              ease: 'power3.out'
            })
            .to('.story-header .section-title', {
              opacity: 1,
              y: 0,
              duration: 1,
              ease: 'power3.out'
            }, '-=0.4')
            .to('.story-text', {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: 'power3.out'
            }, '-=0.6')
            .to('.stat-block', {
              opacity: 1,
              y: 0,
              duration: 0.6,
              ease: 'power3.out',
              stagger: 0.1
            }, '-=0.4');
        }
      });

      // Philosophy section animations with detailed sections
      ScrollTrigger.create({
        trigger: '.about-philosophy',
        start: 'top 80%',
        onEnter: () => {
          const philosophyTl = gsap.timeline();
          
          philosophyTl
            .to('.philosophy-header .section-number', {
              opacity: 1,
              x: 0,
              duration: 0.6,
              ease: 'power3.out'
            })
            .to('.philosophy-header .section-title', {
              opacity: 1,
              y: 0,
              duration: 1,
              ease: 'power3.out'
            }, '-=0.4')
            .to('.philosophy-subtitle', {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: 'power3.out'
            }, '-=0.6')
            .to('.philosophy-line', {
              scaleX: 1,
              duration: 1.5,
              ease: 'power2.out'
            }, '-=0.4');
        }
      });

      // Enhanced parallax line effect on scroll
      ScrollTrigger.create({
        trigger: '.philosophy-line-wrapper',
        start: 'top 80%',
        end: 'bottom 20%',
        scrub: 1,
        onUpdate: (self) => {
          const progress = self.progress;
          const line = document.getElementById('philosophy-line');
          if (line) {
            // Create dynamic scaling effect
            const scale = 0.3 + (progress * 0.7); // Scale from 30% to 100%
            gsap.set(line, {
              scaleX: scale,
              opacity: Math.min(1, progress * 2) // Fade in first half of scroll
            });
          }
        }
      });

      // Philosophy detailed sections animation
      gsap.utils.toArray('.philosophy-section').forEach((section, index) => {
        const element = section as HTMLElement;
        
        ScrollTrigger.create({
          trigger: element,
          start: 'top 85%',
          onEnter: () => {
            element.classList.add('animate');
            console.log(`Philosophy section ${index + 1} animated`);
          }
        });
      });

      // Values section - Performance optimized animations
      ScrollTrigger.create({
        trigger: '.about-values',
        start: 'top 80%',
        onEnter: () => {
          const valuesTl = gsap.timeline();
          
          valuesTl
            .to('.values-header .section-number', {
              opacity: 1,
              x: 0,
              duration: 0.6,
              ease: 'power3.out'
            })
            .to('.values-header .section-title', {
              opacity: 1,
              y: 0,
              duration: 1,
              ease: 'power3.out'
            }, '-=0.4')
            .to('.values-subtitle', {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: 'power3.out'
            }, '-=0.6');
        }
      });

      // Values cards - Lightweight CSS animations instead of heavy GSAP
      const observerOptions = {
        threshold: 0.3,
        rootMargin: '0px 0px -50px 0px'
      };

      const valueObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry, index) => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              entry.target.classList.add('animate');
            }, index * 200); // Stagger delay
            valueObserver.unobserve(entry.target);
          }
        });
      }, observerOptions);

      // Observe all value cards
      document.querySelectorAll('.value-card').forEach(card => {
        valueObserver.observe(card);
      });

      // CTA section animation
      ScrollTrigger.create({
        trigger: '.about-cta',
        start: 'top 80%',
        onEnter: () => {
          gsap.to('.cta-content', {
            opacity: 1,
            y: 0,
            duration: 1,
            ease: 'power3.out'
          });
        }
      });

      console.log('✅ Advanced About page GSAP animations initialized');
    }

    function initFallbackAnimations() {
      console.log('📱 Using fallback about page animations');
      
      // Ensure all content is visible with staggered timing
      const elements = document.querySelectorAll('.hero-badge, .title-word, .hero-description, .section-number, .section-title, .story-text, .stat-block, .philosophy-section, .value-card, .cta-content');
      
      elements.forEach((el, index) => {
        const element = el as HTMLElement;
        setTimeout(() => {
          element.style.opacity = '1';
          element.style.transform = 'translateY(0) translateX(0)';
          element.style.transition = 'all 0.8s ease';
        }, index * 100);
      });
      
      console.log('✅ About page fallback animations complete');
    }

    // Initialize about page animations
    async function initialize() {
      const hasGSAP = await waitForGSAP();
      
      if (hasGSAP) {
        initAdvancedGSAPAnimations();
      } else {
        initFallbackAnimations();
      }
      
      console.log('✅ About page initialization complete');
    }

    // Start initialization
    initialize();

    // Refresh ScrollTrigger on resize
    window.addEventListener('resize', () => {
      if (typeof ScrollTrigger !== 'undefined') {
        ScrollTrigger.refresh();
      }
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAboutPage);
  } else {
    initAboutPage();
  }

  // Page Transition System
  function initPageTransitions() {
    const transitionOverlay = document.getElementById('pageTransition');
    const transitionBg = transitionOverlay?.querySelector('.transition-background') as HTMLElement;
    
    if (!transitionOverlay || !transitionBg) return;

    // Check if we just navigated from another page
    const hasTransitioned = sessionStorage.getItem('pageTransition');
    
    if (hasTransitioned) {
      // Start with overlay covering screen, then slide out
      transitionBg.style.left = '0%';
      setTimeout(() => {
        transitionBg.classList.add('slide-out');
        sessionStorage.removeItem('pageTransition');
        
        // Reset after animation
        setTimeout(() => {
          transitionBg.classList.remove('slide-out');
          transitionBg.style.left = '-100%';
        }, 600);
      }, 100);
    }

    // Handle navigation links
    const navLinks = document.querySelectorAll('a[href^="/"]');
    
    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        const currentPath = window.location.pathname;
        
        // Only handle internal navigation between about and concepts
        if ((href === '/about' || href === '/concepts') && href !== currentPath) {
          e.preventDefault();
          
          // Mark that we're transitioning
          sessionStorage.setItem('pageTransition', 'true');
          
          // Start transition: slide in from left
          transitionBg.classList.add('slide-in');
          
          // Navigate after overlay covers screen
          setTimeout(() => {
            window.location.href = href;
          }, 350);
        }
      });
    });

    console.log('✅ About page transitions initialized');
  }

  // Initialize transitions immediately
  initPageTransitions();
</script> 