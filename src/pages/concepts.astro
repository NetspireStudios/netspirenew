---
import Layout from '../layouts/Layout.astro';
import ConceptsPreloader from '../components/ConceptsPreloader.astro';
---

<Layout title="Concepts - Netspire">
  <!-- Fast Concepts Preloader -->
  <ConceptsPreloader />

  <!-- Import Modular Stylesheets -->
  <link rel="stylesheet" href="/src/styles/base.css" />
  <link rel="stylesheet" href="/src/styles/components/hero.css" />
  <link rel="stylesheet" href="/src/styles/components/project-showcase.css" />
  <link rel="stylesheet" href="/src/styles/components/footer.css" />

  <!-- Page Transition Overlay -->
  <div class="page-transition-overlay" id="pageTransition">
    <div class="transition-background"></div>
  </div>

  <!-- Concepts Hero -->
  <section class="concepts-hero">
    <div class="hero-container">
      <div class="hero-badge">
        <span>Premium Concepts</span>
      </div>
      <h1 class="hero-title">
        <span class="title-word">Website</span>
        <span class="title-word">Concepts</span>
        <span class="title-word">That</span>
        <span class="title-word">Convert</span>
      </h1>
      <div class="hero-description">
        <p>Explore our collection of high-converting website designs built for different industries. Each concept is optimized for maximum conversions and user engagement.</p>
      </div>
    </div>
  </section>

  <!-- Project Showcase Section -->
  <section class="projects-showcase-section">
    <div class="animated-gradient"></div>
    
    <!-- Cinematic Title Section -->
    <div class="cinematic-title-container">
      <div class="title-background-text">CONCEPTS</div>
      <div class="main-title-wrapper">
        <div class="title-line">
          <span class="title-word">Our</span>
        </div>
        <div class="title-line">
          <span class="title-word highlight-word">CONCEPTS</span>
        </div>
      </div>
      <div class="subtitle-container">
        <p class="cinematic-subtitle">Explore our innovative design concepts</p>
      </div>
    </div>

    <div class="projects-container">
      <!-- Enhanced Navigation -->
      <div class="projects-navigation">
        <button class="nav-arrow prev-arrow" id="prevProject">
          <div class="arrow-bg"></div>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Previous</span>
        </button>
        
        <div class="project-counter">
          <span class="current-project" id="currentProject">01</span>
          <div class="counter-divider">
            <span class="divider-line"></span>
            <span class="divider-dot"></span>
            <span class="divider-line"></span>
          </div>
          <span class="total-projects">05</span>
        </div>
        
        <button class="nav-arrow next-arrow" id="nextProject">
          <div class="arrow-bg"></div>
          <span>Next</span>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <!-- Enhanced Project Display -->
      <div class="project-display">
        <div class="project-visual">
          <div class="visual-background"></div>
          <div class="project-image" id="projectImage">
            <div class="image-placeholder">
              <span class="placeholder-text" id="placeholderText">E-COMMERCE PLATFORM</span>
              <div class="placeholder-overlay"></div>
            </div>
          </div>
          <div class="visual-glow"></div>
        </div>

        <div class="project-details">
          <div class="project-header">
            <div class="project-number" id="projectNumber">01</div>
            <div class="project-category" id="projectCategory">E-Commerce</div>
          </div>
          
          <h3 class="project-title" id="projectTitle">Digital Commerce Revolution</h3>
          
          <p class="project-description" id="projectDescription">
            Next-generation e-commerce platform with AI-powered recommendations and seamless user experience.
          </p>
          
          <div class="project-tech" id="projectTech">
            <div class="tech-tag">React</div>
            <div class="tech-tag">Node.js</div>
            <div class="tech-tag">AI/ML</div>
            <div class="tech-tag">WebGL</div>
          </div>

          <div class="project-actions">
            <button class="view-project-btn">
              <span>View Project</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
        
        <!-- Project Indicators -->
        <div class="project-indicators">
          <div class="indicators-container">
            <div class="indicator active" data-project="0">
              <div class="indicator-progress"></div>
            </div>
            <div class="indicator" data-project="1">
              <div class="indicator-progress"></div>
            </div>
            <div class="indicator" data-project="2">
              <div class="indicator-progress"></div>
            </div>
            <div class="indicator" data-project="3">
              <div class="indicator-progress"></div>
            </div>
            <div class="indicator" data-project="4">
              <div class="indicator-progress"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Conversion Importance Section -->
  <section class="conversion-importance">
    <div class="conversion-container">
      <div class="conversion-content">
        <div class="conversion-header">
          <h2>Why Converting Sites Matter?</h2>
          <p class="conversion-intro">
            In today's competitive digital landscape, having a beautiful website isn't enough. 
            Your site needs to convert visitors into customers, and that requires strategic design decisions 
            backed by data and user psychology.
          </p>
        </div>

        <div class="conversion-main">
          <div class="conversion-text">
            <div class="conversion-point">
              <div class="point-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                  <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>User-Centered Design</h3>
              <p>Every element is strategically placed to guide users toward your desired action, reducing friction and increasing conversions by up to 200%.</p>
            </div>

            <div class="conversion-point">
              <div class="point-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                  <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>Speed & Performance</h3>
              <p>Fast-loading sites keep users engaged. Even a 1-second delay can reduce conversions by 7%. Our optimized sites load in under 2 seconds.</p>
            </div>

            <div class="conversion-point">
              <div class="point-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                  <path d="M17 21V19C17 17.9391 16.5786 16.9217 15.8284 16.1716C15.0783 15.4214 14.0609 15 13 15H5C3.93913 15 2.92172 15.4214 2.17157 16.1716C1.42143 16.9217 1 17.9391 1 19V21M9 11C11.2091 11 13 9.20914 13 7C13 4.79086 11.2091 3 9 3C6.79086 3 5 4.79086 5 7C5 9.20914 6.79086 11 9 11ZM23 21V19C22.9993 18.1137 22.7044 17.2528 22.1614 16.5523C21.6184 15.8519 20.8581 15.3516 20 15.13M16 3.13C16.8604 3.35031 17.623 3.85071 18.1676 4.55232C18.7122 5.25392 19.0078 6.11683 19.0078 7.005C19.0078 7.89318 18.7122 8.75608 18.1676 9.45769C17.623 10.1593 16.8604 10.6597 16 10.88" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <h3>Trust & Credibility</h3>
              <p>Professional design builds trust instantly. Users are 38% more likely to engage with well-designed content and make purchasing decisions.</p>
            </div>
          </div>

          <div class="conversion-visual">
            <div class="conversion-image">
              <div class="image-placeholder">
                <svg width="200" height="150" viewBox="0 0 200 150" fill="none">
                  <rect width="200" height="150" rx="12" fill="#f8f9fa"/>
                  <rect x="20" y="20" width="160" height="8" rx="4" fill="#e9ecef"/>
                  <rect x="20" y="40" width="120" height="8" rx="4" fill="#e9ecef"/>
                  <rect x="20" y="70" width="60" height="40" rx="8" fill="#6c757d"/>
                  <rect x="100" y="70" width="80" height="20" rx="4" fill="#e9ecef"/>
                  <rect x="100" y="100" width="60" height="10" rx="4" fill="#e9ecef"/>
                  <circle cx="160" cy="40" r="15" fill="#28a745"/>
                  <path d="M155 40L158 43L165 36" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="image-caption">Conversion-Optimized Design</div>
            </div>
          </div>
        </div>

        <div class="conversion-stats">
          <div class="stats-intro">
            <h3>Our Results Speak for Themselves</h3>
            <p>Here's what happens when you prioritize conversion optimization:</p>
          </div>
          <div class="stats-grid">
            <div class="stat">
              <div class="stat-number">3.2x</div>
              <div class="stat-label">Higher Conversion Rate</div>
            </div>
            <div class="stat">
              <div class="stat-number">47%</div>
              <div class="stat-label">Increase in Sales</div>
            </div>
            <div class="stat">
              <div class="stat-number">68%</div>
              <div class="stat-label">Better User Engagement</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section class="contact-cta-section">
    <div class="cta-container">
      <div class="cta-content">
        <h2>Let's Build Something Amazing Together</h2>
        <p class="cta-subtitle">
          Let's create a conversion-optimized website that drives real results for your business. 
          Book a free consultation call and discover how we can help you succeed.
        </p>
        
        <div class="cta-benefits">
          <div class="benefit">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Free 30-minute strategy session</span>
          </div>
          <div class="benefit">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Custom conversion analysis</span>
          </div>
          <div class="benefit">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Tailored growth recommendations</span>
          </div>
        </div>

        <div class="cta-buttons">
          <a href="#contact" class="cta-button primary">
            Book Your Free Call
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14m-7-7l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#projects" class="cta-button secondary">
            View Our Work
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pre-Footer CTA Section -->
  <section class="pre-footer-cta">
    <div class="pre-footer-container">
      <div class="pre-footer-content">
        <div class="cta-main">
          <h2 class="cta-title">Ready to Transform Your Business?</h2>
          <p class="cta-description">Join hundreds of companies that have revolutionized their digital presence with our conversion-optimized designs.</p>
          <div class="cta-action">
            <a href="#contact" class="cta-primary-btn">
              <span>Start Your Project</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="#contact" class="cta-secondary-btn">
              <span>Schedule Consultation</span>
            </a>
          </div>
        </div>
        <div class="cta-stats">
          <div class="stat-item">
            <div class="stat-number">250%</div>
            <div class="stat-label">Avg. Conversion Increase</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">48hrs</div>
            <div class="stat-label">First Draft Delivery</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Client Satisfaction</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="concepts-footer">
    <div class="footer-container">
      <div class="footer-content">
        <div class="footer-brand">
          <h3 class="footer-logo">NETSPIRE</h3>
          <p class="footer-tagline">Cinematic digital experiences that convert</p>
          <div class="footer-cta">
            <p class="footer-cta-text">Ready to get started?</p>
            <a href="#contact" class="footer-cta-btn">Get In Touch</a>
          </div>
        </div>
        
        <div class="footer-links">
          <div class="footer-column">
            <h4 class="footer-title">Services</h4>
            <ul class="footer-list">
              <li><a href="#services">Web Design</a></li>
              <li><a href="#services">Development</a></li>
              <li><a href="#services">Optimization</a></li>
              <li><a href="#services">Consulting</a></li>
            </ul>
          </div>
          
          <div class="footer-column">
            <h4 class="footer-title">Company</h4>
            <ul class="footer-list">
              <li><a href="/about">About Us</a></li>
              <li><a href="/concepts">Concepts</a></li>
              <li><a href="#portfolio">Portfolio</a></li>
              <li><a href="#contact">Contact</a></li>
            </ul>
          </div>
          
          <div class="footer-column">
            <h4 class="footer-title">Connect</h4>
            <ul class="footer-list">
              <li><a href="https://www.instagram.com/netspirestudio" target="_blank">Instagram</a></li>
              <li><a href="https://www.linkedin.com/company/netspirestudio" target="_blank">LinkedIn</a></li>
              <li><a href="#contact">Email Us</a></li>
              <li><a href="#contact">Book a Call</a></li>
            </ul>
          </div>
        </div>
      </div>
      
      <div class="footer-bottom">
        <div class="footer-copyright">
          <p>&copy; 2024 NETSPIRE. All rights reserved.</p>
        </div>
        <div class="footer-legal">
          <a href="#privacy">Privacy Policy</a>
          <a href="#terms">Terms of Service</a>
        </div>
      </div>
    </div>
  </footer>
</Layout>

<!-- Import Modular JavaScript -->
<script type="module">
  import { initHeroAnimations, initTitleAnimation, initPageTransitions } from '/src/scripts/concepts-animations.js';
  import { initProjectShowcase } from '/src/scripts/project-showcase.js';

  // Initialize all modules when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    console.log('🚀 Initializing Concepts Page...');
    
    // Initialize animations
    initHeroAnimations();
    initTitleAnimation();
    initPageTransitions();
    
    // Initialize interactive components
    initProjectShowcase();
    
    console.log('✅ Concepts Page initialized successfully');
  });
</script>

<!-- Add missing CSS for sections not yet extracted -->
<style>
  /* Conversion Importance Section */
  .conversion-importance {
    padding: 120px 0;
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  }

  .conversion-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .conversion-content {
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .conversion-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .conversion-header h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #000000;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .conversion-intro {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    line-height: 1.6;
    color: #666666;
    margin: 0;
  }

  .conversion-main {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .conversion-text {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .conversion-point {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  .point-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    color: #000000;
  }

  .conversion-point h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #000000;
    margin: 0 0 12px 0;
  }

  .conversion-point p {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: #666666;
    margin: 0;
  }

  .conversion-visual {
    display: flex;
    justify-content: center;
  }

  .conversion-image {
    text-align: center;
  }

  .image-caption {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #666666;
    margin-top: 16px;
    font-weight: 500;
  }

  .conversion-stats {
    text-align: center;
  }

  .stats-intro h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2rem;
    font-weight: 600;
    color: #000000;
    margin-bottom: 16px;
  }

  .stats-intro p {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #666666;
    margin-bottom: 40px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .stat {
    text-align: center;
  }

  .stat-number {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 3rem;
    font-weight: 700;
    color: #000000;
    margin-bottom: 8px;
  }

  .stat-label {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #666666;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Contact CTA Section */
  .contact-cta-section {
    padding: 120px 0;
    background: #000000;
    color: white;
  }

  .cta-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 60px;
    text-align: center;
  }

  .cta-content h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .cta-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-benefits {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-bottom: 50px;
    flex-wrap: wrap;
  }

  .benefit {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.9);
  }

  .benefit svg {
    color: #ffffff;
    flex-shrink: 0;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    border-radius: 50px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .cta-button.primary {
    background: #ffffff;
    color: #000000;
    border: 2px solid #ffffff;
  }

  .cta-button.primary:hover {
    background: transparent;
    color: #ffffff;
    transform: translateY(-2px);
  }

  .cta-button.secondary {
    background: transparent;
    color: #ffffff;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }

  .cta-button.secondary:hover {
    border-color: #ffffff;
    background: #ffffff;
    color: #000000;
    transform: translateY(-2px);
  }

  /* Project Indicators Styles */
  .project-indicators {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    opacity: 1;
  }

  .indicators-container {
    display: flex;
    gap: 20px;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(20px);
    padding: 20px 30px;
    border-radius: 50px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .indicator {
    position: relative;
    width: 50px;
    height: 8px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.4s ease;
    overflow: hidden;
  }

  .indicator-progress {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0;
    background: linear-gradient(135deg, #ffffff 0%, #cccccc 100%);
    border-radius: 4px;
    transition: width 0.4s ease;
  }

  .indicator.active {
    background: rgba(255, 255, 255, 0.3);
  }

  .indicator.active .indicator-progress {
    width: 100%;
  }

  .indicator:hover {
    background: rgba(255, 255, 255, 0.4);
    transform: scale(1.1);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .conversion-container,
    .cta-container {
      padding: 0 20px;
    }

    .conversion-main {
      grid-template-columns: 1fr;
      gap: 50px;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

