---
import Layout from '../layouts/Layout.astro';
import ConceptsPreloader from '../components/ConceptsPreloader.astro';
---

<Layout title="Concepts - Netspire">
  <!-- Fast Concepts Preloader -->
  <ConceptsPreloader />

  <!-- Page Transition Overlay -->
  <div class="page-transition-overlay" id="pageTransition">
    <div class="transition-background"></div>
  </div>

  <!-- Essential CSS for Mobile Compatibility -->
  <style>
    /* Reset and Base Styles */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    /* Page Transition System */
    .page-transition-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 9999;
      pointer-events: none;
      overflow: hidden;
    }

    .transition-background {
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: #000000;
      transition: none;
    }

    .transition-background.slide-in {
      left: 0;
      transition: left 0.6s ease-in-out;
    }

    .transition-background.slide-out {
      left: 100%;
      transition: left 0.6s ease-in-out;
    }

    /* Hero Section */
    .concepts-hero {
      min-height: 100vh;
      background: linear-gradient(135deg, #000 0%, #1a1a1a 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      position: relative;
      overflow: hidden;
    }

    .hero-container {
      max-width: 1200px;
      width: 100%;
      padding: 0 60px;
      text-align: center;
      z-index: 2;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      padding: 12px 24px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 30px;
      margin-bottom: 40px;
      backdrop-filter: blur(10px);
      opacity: 1;
      transform: translateY(0);
    }

    .hero-badge span {
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 500;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .hero-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(3rem, 8vw, 7rem);
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 40px;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 20px;
    }

    .title-word {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-description {
      max-width: 600px;
      margin: 0 auto;
      opacity: 1;
      transform: translateY(0);
    }

    .hero-description p {
      font-family: 'Inter', sans-serif;
      font-size: 18px;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.8);
    }

    @media (max-width: 768px) {
      .hero-container {
        padding: 0 20px;
      }
      
      .hero-title {
        font-size: clamp(2rem, 8vw, 4rem);
        gap: 10px;
      }
      
      .hero-description p {
        font-size: 16px;
      }
    }
  </style>

  <!-- Concepts Hero -->
  <section class="concepts-hero">
    <div class="hero-container">
      <div class="hero-badge">
        <span>Premium Concepts</span>
      </div>
      <h1 class="hero-title">
        <span class="title-word">Website</span>
        <span class="title-word">Concepts</span>
        <span class="title-word">That</span>
        <span class="title-word">Convert</span>
      </h1>
      <div class="hero-description">
        <p>Explore our collection of high-converting website designs built for different industries. Each concept is optimized for maximum conversions and user engagement.</p>
      </div>
    </div>
  </section>

  <!-- Project Showcase Section -->
  <section class="projects-showcase-section">
    <div class="animated-gradient"></div>
    
    <!-- Cinematic Title Section -->
    <div class="cinematic-title-container">
      <div class="title-background-text">CONCEPTS</div>
      <div class="main-title-wrapper">
        <div class="title-line">
          <span class="title-word">Our</span>
        </div>
        <div class="title-line">
          <span class="title-word highlight-word">CONCEPTS</span>
        </div>
      </div>
      <div class="subtitle-container">
        <p class="cinematic-subtitle">Explore our innovative design concepts</p>
      </div>
    </div>

    <div class="projects-container">
      <!-- Enhanced Navigation -->
      <div class="projects-navigation">
        <button class="nav-arrow prev-arrow" id="prevProject">
          <div class="arrow-bg"></div>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Previous</span>
        </button>
        
        <div class="project-counter">
          <span class="current-project" id="currentProject">01</span>
          <div class="counter-divider">
            <span class="divider-line"></span>
            <span class="divider-dot"></span>
            <span class="divider-line"></span>
          </div>
          <span class="total-projects">06</span>
        </div>
        
        <button class="nav-arrow next-arrow" id="nextProject">
          <div class="arrow-bg"></div>
          <span>Next</span>
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <!-- Swipe Instruction (Mobile Only) -->
      <div class="swipe-instruction">Swipe</div>

      <!-- Enhanced Project Display -->
      <div class="project-display">
        <div class="project-visual">
          <div class="visual-background"></div>
          <div class="project-image" id="projectImage">
            <div class="image-placeholder">
              <span class="placeholder-text" id="placeholderText">AI AGENTS PLATFORM</span>
              <div class="placeholder-overlay"></div>
            </div>
          </div>
          <div class="visual-glow"></div>
        </div>

        <div class="project-details">
          <div class="project-header">
            <div class="project-number" id="projectNumber">01</div>
            <div class="project-category" id="projectCategory">AI & Automation</div>
          </div>
          
          <h3 class="project-title" id="projectTitle">Intelligent Business Solutions</h3>
          
          <p class="project-description" id="projectDescription">
            Sophisticated yet approachable design for AI services. Features interactive demos, trust signals, and clear ROI calculators.
          </p>
          
          <div class="project-tech" id="projectTech">
            <div class="tech-tag">24/7 Support</div>
            <div class="tech-tag">Automation</div>
            <div class="tech-tag">Analytics</div>
            <div class="tech-tag">AI Training</div>
          </div>

          <div class="project-actions">
            <button class="view-project-btn">
              <span>View Project</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
        
      </div>
    </div>
  </section>

  <!-- Why Our Concepts Work -->
  <section class="concepts-value">
    <div class="value-container">
      <div class="value-content">
        <div class="value-header">
          <h2>Why Our Concepts Drive Results</h2>
          <p>Every design decision is backed by conversion psychology and real-world testing.</p>
        </div>

        <div class="value-grid">
          <div class="value-item">
            <div class="value-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Conversion Psychology</h3>
            <p>Every element is positioned using proven psychology principles that guide users toward your desired action.</p>
          </div>

          <div class="value-item">
            <div class="value-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Lightning Fast</h3>
            <p>Optimized for speed with under 2-second load times. Fast sites convert 2.5x better than slow ones.</p>
          </div>

          <div class="value-item">
            <div class="value-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Mobile-First Design</h3>
            <p>Designed for mobile users first, ensuring perfect experiences across all devices and screen sizes.</p>
          </div>

          <div class="value-item">
            <div class="value-icon">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                <path d="M22 12H18L15 21L9 3L6 12H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Data-Driven</h3>
            <p>Each concept is tested and optimized based on real user behavior and conversion data.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section class="contact-cta-section">
    <div class="cta-container">
      <div class="cta-content">
        <h2>Let's Build Something Amazing Together</h2>
        <p class="cta-subtitle">
          Let's create a conversion-optimized website that drives real results for your business. 
          Book a free consultation call and discover how we can help you succeed.
        </p>
        
        <div class="cta-benefits">
          <div class="benefit">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Free 30-minute strategy session</span>
          </div>
          <div class="benefit">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Custom conversion analysis</span>
          </div>
          <div class="benefit">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Tailored growth recommendations</span>
          </div>
        </div>

        <div class="cta-buttons">
          <a href="#contact" class="cta-button primary">
            Book Your Free Call
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14m-7-7l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#projects" class="cta-button secondary">
            View Our Work
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>



  <!-- Footer -->
  <footer class="concepts-footer">
    <div class="footer-container">
      <div class="footer-content">
        <div class="footer-brand">
          <h3 class="footer-logo">NETSPIRE</h3>
          <p class="footer-tagline">Cinematic digital experiences that convert</p>
          <div class="footer-cta">
            <p class="footer-cta-text">Ready to get started?</p>
            <a href="#contact" class="footer-cta-btn">Get In Touch</a>
          </div>
        </div>
        
        <div class="footer-links">
          <div class="footer-column">
            <h4 class="footer-title">Services</h4>
            <ul class="footer-list">
              <li><a href="#services">Web Design</a></li>
              <li><a href="#services">Development</a></li>
              <li><a href="#services">Optimization</a></li>
              <li><a href="#services">Consulting</a></li>
            </ul>
          </div>
          
          <div class="footer-column">
            <h4 class="footer-title">Company</h4>
            <ul class="footer-list">
              <li><a href="/about">About Us</a></li>
              <li><a href="/concepts">Concepts</a></li>
              <li><a href="#portfolio">Portfolio</a></li>
              <li><a href="#contact">Contact</a></li>
            </ul>
          </div>
          
          <div class="footer-column">
            <h4 class="footer-title">Connect</h4>
            <ul class="footer-list">
              <li><a href="https://www.instagram.com/netspirestudio" target="_blank">Instagram</a></li>
              <li><a href="https://www.linkedin.com/company/netspirestudio" target="_blank">LinkedIn</a></li>
              <li><a href="#contact">Email Us</a></li>
              <li><a href="#contact">Book a Call</a></li>
            </ul>
          </div>
        </div>
      </div>
      
      <div class="footer-bottom">
        <div class="footer-copyright">
          <p>&copy; 2024 NETSPIRE. All rights reserved.</p>
        </div>
        <div class="footer-legal">
          <a href="#privacy">Privacy Policy</a>
          <a href="#terms">Terms of Service</a>
        </div>
      </div>
    </div>
  </footer>
</Layout>

<!-- Import Modular JavaScript -->
<script type="module">
  import { initHeroAnimations, initTitleAnimation, initPageTransitions } from '/src/scripts/concepts-animations.js';

  // Initialize all modules when DOM is ready
  document.addEventListener('DOMContentLoaded', () => {
    console.log('🚀 Initializing Concepts Page...');
    
    // Initialize animations
    initHeroAnimations();
    initTitleAnimation();
    initPageTransitions();
    
    console.log('✅ Concepts Page initialized successfully');
  });
</script>

<!-- Simple Direct Project Carousel -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  console.log('🎯 Starting simple carousel...');
  
  // Project data
  const projects = [
    {
      number: '01',
      category: 'AI & Automation',
      title: 'Intelligent Business Solutions',
      description: 'Sophisticated yet approachable design for AI services. Features interactive demos, trust signals, and clear ROI calculators.',
      placeholder: 'AI AGENTS PLATFORM',
      tags: ['24/7 Support', 'Automation', 'Analytics', 'AI Training']
    },
    {
      number: '02',
      category: 'Mobile Development',
      title: 'App Development Showcase',
      description: 'Clean, modern design highlighting app portfolios with interactive prototypes and detailed development process.',
      placeholder: 'APP DEVELOPMENT',
      tags: ['iOS Apps', 'Android', 'Cross-Platform', 'App Store']
    },
    {
      number: '03',
      category: 'Web Development',
      title: 'Professional Web Agency',
      description: 'Authority-building design with comprehensive service pages, live speed tests, and social proof integration.',
      placeholder: 'WEB AGENCY',
      tags: ['Frontend', 'Backend', 'E-commerce', 'Security']
    },
    {
      number: '04',
      category: 'Performance & Speed',
      title: 'Speed Optimization Dashboard',
      description: 'Technical yet accessible design showcasing performance improvements with live metrics and instant audits.',
      placeholder: 'SPEED OPTIMIZATION',
      tags: ['Speed Tests', 'Caching', 'CDN', 'Monitoring']
    },
    {
      number: '05',
      category: 'SEO & Marketing',
      title: 'SEO Growth Platform',
      description: 'Credibility-focused design with live ranking displays, detailed case studies, and transparent reporting tools.',
      placeholder: 'SEO PLATFORM',
      tags: ['Keyword Research', 'Rankings', 'Analytics', 'Reports']
    },
    {
      number: '06',
      category: 'API & Integration',
      title: 'Developer Platform',
      description: 'Technical yet user-friendly design with interactive documentation, API testing tools, and comprehensive guides.',
      placeholder: 'DEVELOPER PLATFORM',
      tags: ['REST API', 'GraphQL', 'Webhooks', 'Documentation']
    }
  ];
  
  let currentIndex = 0;
  
  /**
   * @param {number} projectIndex
   */
  function updateProject(projectIndex) {
    console.log('📝 Updating to project:', projectIndex + 1);
    const project = projects[projectIndex];
    
    // Add fade out effect
    const projectDisplay = document.querySelector('.project-display');
    if (projectDisplay) {
      projectDisplay.style.opacity = '0.7';
      projectDisplay.style.transform = 'scale(0.98)';
    }
    
    // Update content after a brief delay for smooth transition
    setTimeout(() => {
      // Update all elements
      const currentProjectEl = document.getElementById('currentProject');
      const projectNumberEl = document.getElementById('projectNumber');
      const projectCategoryEl = document.getElementById('projectCategory');
      const projectTitleEl = document.getElementById('projectTitle');
      const projectDescriptionEl = document.getElementById('projectDescription');
      
      // Update basic content
      if (currentProjectEl) currentProjectEl.textContent = (projectIndex + 1).toString().padStart(2, '0');
      if (projectNumberEl) projectNumberEl.textContent = project.number;
      if (projectCategoryEl) projectCategoryEl.textContent = project.category;
      if (projectTitleEl) projectTitleEl.textContent = project.title;
      if (projectDescriptionEl) projectDescriptionEl.textContent = project.description;
      
      // Update image instead of placeholder text
      const projectImageEl = document.querySelector('.project-image');
      if (projectImageEl) {
        projectImageEl.innerHTML = `
          <div class="image-placeholder">
            <span class="placeholder-text">${project.placeholder}</span>
            <div class="placeholder-overlay"></div>
          </div>
        `;
      }
      
      // Update tech tags
      const projectTechEl = document.getElementById('projectTech');
      if (projectTechEl) {
        projectTechEl.innerHTML = project.tags.map(tag => `<div class="tech-tag">${tag}</div>`).join('');
      }
      
      // Fade back in
      if (projectDisplay) {
        projectDisplay.style.opacity = '1';
        projectDisplay.style.transform = 'scale(1)';
      }
      
      currentIndex = projectIndex;
      console.log('✅ Project updated successfully');
    }, 150);
  }
  
  function nextProject() {
    console.log('➡️ Going to next project');
    const nextIndex = (currentIndex + 1) % projects.length;
    
    // Add swipe animation
    const projectDisplay = document.querySelector('.project-display');
    if (projectDisplay) {
      projectDisplay.classList.add('swipe-left');
      setTimeout(() => {
        projectDisplay.classList.remove('swipe-left');
      }, 400);
    }
    
    updateProject(nextIndex);
  }
  
  function prevProject() {
    console.log('⬅️ Going to previous project');
    const prevIndex = (currentIndex - 1 + projects.length) % projects.length;
    
    // Add swipe animation
    const projectDisplay = document.querySelector('.project-display');
    if (projectDisplay) {
      projectDisplay.classList.add('swipe-right');
      setTimeout(() => {
        projectDisplay.classList.remove('swipe-right');
      }, 400);
    }
    
    updateProject(prevIndex);
  }
  
  // Add event listeners
  const nextBtn = document.getElementById('nextProject');
  const prevBtn = document.getElementById('prevProject');
  
  if (nextBtn) {
    nextBtn.addEventListener('click', function(e) {
      e.preventDefault();
      console.log('🔥 Next button clicked!');
      nextProject();
    });
  }
  
  if (prevBtn) {
    prevBtn.addEventListener('click', function(e) {
      e.preventDefault();
      console.log('🔥 Previous button clicked!');
      prevProject();
    });
  }
  
  // Add touch/swipe functionality for mobile
  let touchStartX = 0;
  let touchStartY = 0;
  let isTouch = false;
  let isDragging = false;
  
  const projectDisplay = document.querySelector('.project-display');
  
  document.addEventListener('touchstart', function(e) {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    isTouch = true;
    isDragging = false;
  });

  document.addEventListener('touchmove', function(e) {
    if (!isTouch) return;
    
    const currentX = e.touches[0].clientX;
    const currentY = e.touches[0].clientY;
    const deltaX = Math.abs(currentX - touchStartX);
    const deltaY = Math.abs(currentY - touchStartY);
    
    // Only trigger horizontal swipe if moving more horizontally than vertically
    if (deltaX > deltaY && deltaX > 10) {
      isDragging = true;
      e.preventDefault(); // Prevent page scroll during horizontal swipe
      
      // Add visual feedback during drag
      const progress = Math.min(deltaX / 100, 1);
      if (projectDisplay) {
        projectDisplay.style.transform = `scale(${1 - progress * 0.05})`;
        projectDisplay.style.opacity = `${1 - progress * 0.1}`;
      }
    }
  }, { passive: false });

  document.addEventListener('touchend', function(e) {
    if (!isTouch) return;
    
    const touchEndX = e.changedTouches[0].clientX;
    const swipeDistance = touchStartX - touchEndX;
    
    // Reset visual feedback
    if (projectDisplay) {
      projectDisplay.style.transform = '';
      projectDisplay.style.opacity = '';
    }
    
    // Only trigger swipe if we were actually dragging horizontally
    if (isDragging && Math.abs(swipeDistance) > 30) {
      if (swipeDistance > 0) {
        console.log('👉 Swiped left (next)');
        nextProject();
      } else {
        console.log('👈 Swiped right (prev)');
        prevProject();
      }
    }
    
    isTouch = false;
    isDragging = false;
  });
  
  console.log('✅ Carousel initialized with', projects.length, 'projects');
});
</script>

<!-- Add missing CSS for sections not yet extracted -->
<style>
  /* Value Section - Keep from new design */
  .concepts-value {
    background: #f8f9fa;
    padding: 80px 0;
  }

  .value-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .value-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .value-header h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: #000;
    margin-bottom: 16px;
  }

  .value-header p {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    color: #666;
    line-height: 1.6;
  }

  .value-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .value-item {
    text-align: center;
    padding: 20px;
  }

  .value-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 24px;
    color: #000;
  }

  .value-item h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: #000;
    margin-bottom: 12px;
  }

  .value-item p {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: #666;
  }

  /* Responsive for value section */
  @media (min-width: 768px) {
    .value-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

