---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Portfolio from '../components/Portfolio.astro';
import Contact from '../components/Contact.astro';
import Quote from '../components/Quote.astro';
---

<Layout title="NETSPIRE - Cinematic Web Experience" description="Experience the future of web design with NETSPIRE's cinematic approach to digital creativity.">
  <!-- Hero Section -->
  <Hero />
  
  <!-- Quote Section 1 -->
  <Quote 
    quote="Innovation is seeing what everybody has seen and thinking what nobody has thought."
    author="Dr. Albert Szent-Györgyi"
    role="Nobel Prize Winner"
    shapeType="cube"
  />
  
  <!-- Services Section -->
  <Services />
  
  <!-- Quote Section 2 -->
  <Quote 
    quote="The best way to predict the future is to design it."
    author="Buckminster Fuller"
    role="Architect & Inventor"
    shapeType="sphere"
  />
  
  <!-- Portfolio Section -->
  <Portfolio />
  
  <!-- Quote Section 3 -->
  <Quote 
    quote="Design is not just what it looks like and feels like. Design is how it works."
    author="Steve Jobs"
    role="Apple Co-founder"
    shapeType="tetrahedron"
  />
  
  <!-- Contact Section -->
  <Contact />
</Layout>
