---
// Concepts Header Component - Extracted for Performance
---

<section class="concepts-hero">
  <div class="hero-container">
    <div class="hero-badge">
      <span>Premium Concepts</span>
    </div>
    <h1 class="hero-title">
      <span class="title-word">Website</span>
      <span class="title-word">Concepts</span>
      <span class="title-word">That</span>
      <span class="title-word">Convert</span>
    </h1>
    <div class="hero-description">
      <p>Explore our collection of high-converting website designs built for different industries. Each concept is optimized for maximum conversions and user engagement.</p>
    </div>
  </div>
</section>

<style>
  /* Concepts Hero Section */
  .concepts-hero {
    min-height: 70vh;
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 0 80px 0;
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
    text-align: center;
    z-index: 10;
    position: relative;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 8px 20px;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 50px;
    margin-bottom: 30px;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 1s ease 0.2s forwards;
  }

  .hero-badge span {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #333333;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .hero-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 700;
    color: #000000;
    line-height: 1.1;
    margin: 0 0 30px 0;
    letter-spacing: -0.02em;
  }

  .title-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(60px);
    animation: fadeInUp 1s ease forwards;
  }

  .title-word:nth-child(1) { animation-delay: 0.3s; }
  .title-word:nth-child(2) { animation-delay: 0.4s; }
  .title-word:nth-child(3) { animation-delay: 0.5s; }
  .title-word:nth-child(4) { animation-delay: 0.6s; }

  .hero-description {
    max-width: 600px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 1s ease 0.8s forwards;
  }

  .hero-description p {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    line-height: 1.6;
    color: #666666;
    margin: 0;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .concepts-hero {
      min-height: 60vh;
      padding: 100px 0 60px 0;
    }

    .hero-container {
      padding: 0 30px;
    }

    .hero-description p {
      font-size: 16px;
    }
  }

  @media (max-width: 480px) {
    .hero-container {
      padding: 0 20px;
    }

    .hero-description p {
      font-size: 15px;
    }
  }
</style> 