<script>
  import * as THREE from 'three';

  // Enhanced Three.js Scene with Large Side Shapes
  function initServicesBackground() {
    const canvas = document.getElementById('services-canvas');
    if (!canvas) return;

    console.log('🎨 Initializing enhanced Three.js services background...');

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ 
      canvas: canvas,
      alpha: true,
      antialias: true 
    });

    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Create large geometric shapes for sides
    interface ShapeData {
      mesh: THREE.Mesh;
      rotationSpeed: { x: number; y: number; z: number };
      floatAmplitude: number;
      floatSpeed: number;
    }
    
    const shapes: ShapeData[] = [];

    // Left side large octahedron
    const leftGeometry = new THREE.OctahedronGeometry(4);
    const leftMaterial = new THREE.MeshBasicMaterial({ 
      color: 0x000000,
      wireframe: true,
      transparent: true,
      opacity: 0.15
    });
    const leftShape = new THREE.Mesh(leftGeometry, leftMaterial);
    leftShape.position.set(-12, 2, -5);
    leftShape.rotation.set(0.5, 0.5, 0);
    scene.add(leftShape);
    shapes.push({
      mesh: leftShape,
      rotationSpeed: { x: 0.005, y: 0.008, z: 0.003 },
      floatAmplitude: 1.5,
      floatSpeed: 0.01
    });

    // Right side large dodecahedron
    const rightGeometry = new THREE.DodecahedronGeometry(3);
    const rightMaterial = new THREE.MeshBasicMaterial({ 
      color: 0x000000,
      wireframe: true,
      transparent: true,
      opacity: 0.12
    });
    const rightShape = new THREE.Mesh(rightGeometry, rightMaterial);
    rightShape.position.set(12, -1, -3);
    rightShape.rotation.set(0.3, 0.8, 0.2);
    scene.add(rightShape);
    shapes.push({
      mesh: rightShape,
      rotationSpeed: { x: 0.008, y: 0.005, z: 0.007 },
      floatAmplitude: 2,
      floatSpeed: 0.008
    });

    // Center floating tetrahedron (smaller)
    const centerGeometry = new THREE.TetrahedronGeometry(2);
    const centerMaterial = new THREE.MeshBasicMaterial({ 
      color: 0x000000,
      wireframe: true,
      transparent: true,
      opacity: 0.08
    });
    const centerShape = new THREE.Mesh(centerGeometry, centerMaterial);
    centerShape.position.set(0, 4, -8);
    centerShape.rotation.set(0.8, 0.3, 0.5);
    scene.add(centerShape);
    shapes.push({
      mesh: centerShape,
      rotationSpeed: { x: 0.01, y: 0.012, z: 0.008 },
      floatAmplitude: 1,
      floatSpeed: 0.015
    });

    camera.position.z = 8;

    let animationId: number;
    let startTime = Date.now();

    // Enhanced animation loop with smooth transitions
    function animate() {
      animationId = requestAnimationFrame(animate);

      const time = (Date.now() - startTime) * 0.001;

      shapes.forEach((shape) => {
        // Rotation
        shape.mesh.rotation.x += shape.rotationSpeed.x;
        shape.mesh.rotation.y += shape.rotationSpeed.y;
        shape.mesh.rotation.z += shape.rotationSpeed.z;
        
        // Floating motion
        const originalY = shape.mesh.userData.originalY || shape.mesh.position.y;
        if (!shape.mesh.userData.originalY) {
          shape.mesh.userData.originalY = originalY;
        }
        
        shape.mesh.position.y = originalY + Math.sin(time * shape.floatSpeed) * shape.floatAmplitude;
        
        // Subtle side-to-side movement
        const originalX = shape.mesh.userData.originalX || shape.mesh.position.x;
        if (!shape.mesh.userData.originalX) {
          shape.mesh.userData.originalX = originalX;
        }
        
        shape.mesh.position.x = originalX + Math.sin(time * shape.floatSpeed * 0.7) * 0.3;
      });

      renderer.render(scene, camera);
    }

    animate();

    // Handle resize
    function handleResize() {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    }

    window.addEventListener('resize', handleResize);

    console.log('✅ Enhanced Three.js services background initialized');

    // Cleanup function
    return () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', handleResize);
      shapes.forEach(shape => {
        scene.remove(shape.mesh);
        shape.mesh.geometry.dispose();
        if (Array.isArray(shape.mesh.material)) {
          shape.mesh.material.forEach(material => material.dispose());
        } else {
          shape.mesh.material.dispose();
        }
      });
      renderer.dispose();
    };
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initServicesBackground);
  } else {
    initServicesBackground();
  }
</script> 