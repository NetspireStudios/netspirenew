---
// Enhanced Services Section with Three.js - Cinematic Style
---

<section class="services" id="services">
  <!-- Three.js Background -->
  <canvas id="services-canvas" class="services-canvas"></canvas>
  
  <div class="services-container">
    <!-- Section Header with Quote -->
    <div class="services-header">
      <div class="section-label">
        <span>— What We Create</span>
      </div>
      
      <!-- Inspiring Quote for Global Design -->
      <div class="services-quote">
        <blockquote class="quote-text">
          "Design is not just what it looks like and feels like. Design is how it works — across every corner of our connected world."
        </blockquote>
        <div class="quote-attribution">
          <span class="quote-author">Inspired by Steve Jobs</span>
          <span class="quote-context">For the Digital Age</span>
        </div>
      </div>
      
      <h2 class="section-title">
        <div class="title-line">
          <span class="title-word">Global Digital</span>
        </div>
        <div class="title-line">
          <span class="title-word">Excellence</span>
        </div>
      </h2>
      <p class="section-description">
        We craft world-class digital experiences that transcend boundaries, connecting 
        your brand with audiences across the globe through innovative design and technology.
      </p>
    </div>

    <!-- Services Grid with 3D Cards -->
    <div class="services-grid">
      <!-- Service 1 - Web Development -->
      <article class="service-item" data-service="01" data-cursor="hover">
        <div class="service-3d-container">
          <div class="service-card">
            <div class="service-number">01</div>
            <div class="service-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2" stroke="currentColor" stroke-width="1.5"/>
                <line x1="8" y1="21" x2="16" y2="21" stroke="currentColor" stroke-width="1.5"/>
                <line x1="12" y1="17" x2="12" y2="21" stroke="currentColor" stroke-width="1.5"/>
                <path d="m7 13 3-3-3-3m8 0v6" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </div>
            <h3 class="service-title">Web Development</h3>
            <p class="service-description">
              Crafting responsive, performance-optimized websites that deliver 
              exceptional user experiences across all devices and platforms.
            </p>
            <ul class="service-features">
              <li>React & Next.js</li>
              <li>Performance Optimization</li>
              <li>Custom CMS Solutions</li>
              <li>E-commerce Platforms</li>
            </ul>
            <div class="service-hover-element"></div>
          </div>
        </div>
      </article>

      <!-- Service 2 - Design Systems -->
      <article class="service-item" data-service="02" data-cursor="hover">
        <div class="service-3d-container">
          <div class="service-card">
            <div class="service-number">02</div>
            <div class="service-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </div>
            <h3 class="service-title">Design Systems</h3>
            <p class="service-description">
              Building cohesive design languages that scale across products, 
              ensuring consistency and efficiency in every interaction.
            </p>
            <ul class="service-features">
              <li>Component Libraries</li>
              <li>Design Tokens</li>
              <li>Style Guides</li>
              <li>Accessibility Standards</li>
            </ul>
            <div class="service-hover-element"></div>
          </div>
        </div>
      </article>

      <!-- Service 3 - 3D Experiences -->
      <article class="service-item" data-service="03" data-cursor="hover">
        <div class="service-3d-container">
          <div class="service-card">
            <div class="service-number">03</div>
            <div class="service-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <path d="M2 3h20l-2 14H4L2 3z" stroke="currentColor" stroke-width="1.5"/>
                <path d="M6 8h12l-1 6H7L6 8z" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="9" cy="19" r="2" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="20" cy="19" r="2" stroke="currentColor" stroke-width="1.5"/>
                <path d="M2 3l2 14h16" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </div>
            <h3 class="service-title">3D Experiences</h3>
            <p class="service-description">
              Creating immersive 3D interfaces and animations that push the 
              boundaries of web technology and user engagement.
            </p>
            <ul class="service-features">
              <li>Three.js Integration</li>
              <li>WebGL Experiences</li>
              <li>Interactive 3D Models</li>
              <li>Real-time Rendering</li>
            </ul>
            <div class="service-hover-element"></div>
          </div>
        </div>
      </article>

      <!-- Service 4 - Digital Strategy -->
      <article class="service-item" data-service="04" data-cursor="hover">
        <div class="service-3d-container">
          <div class="service-card">
            <div class="service-number">04</div>
            <div class="service-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <path d="M9 11H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2h-4" stroke="currentColor" stroke-width="1.5"/>
                <path d="M9 7l3-3 3 3M12 4v8" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="7" cy="17" r="1" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </div>
            <h3 class="service-title">Digital Strategy</h3>
            <p class="service-description">
              Developing comprehensive digital strategies that align technology 
              with business objectives for measurable growth.
            </p>
            <ul class="service-features">
              <li>Technology Consulting</li>
              <li>User Experience Strategy</li>
              <li>Performance Analytics</li>
              <li>Growth Optimization</li>
            </ul>
            <div class="service-hover-element"></div>
          </div>
        </div>
      </article>
    </div>

    <!-- Call to Action -->
    <div class="services-cta">
      <h3 class="cta-title">Ready to innovate?</h3>
      <p class="cta-description">Let's create something extraordinary together.</p>
      <button class="cta-button" data-cursor="hover">
        <span>Start Your Project</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M1 8H15M15 8L8 1M15 8L8 15" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .services {
    position: relative;
    min-height: 120vh;
    padding: 140px 0 100px;
    background: linear-gradient(135deg, #fafafa 0%, #ffffff 50%, #f8f8f8 100%);
    overflow: hidden;
  }

  /* Three.js Canvas */
  .services-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    opacity: 0.6;
  }

  .services-container {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 60px;
  }

  /* Header */
  .services-header {
    text-align: center;
    margin-bottom: 120px;
  }

  .section-label {
    margin-bottom: 30px;
  }

  .section-label span {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: #666;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* Services Quote Section */
  .services-quote {
    max-width: 800px;
    margin: 60px auto 40px auto;
    text-align: center;
    padding: 40px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
  }

  .quote-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 400;
    line-height: 1.6;
    color: #ffffff;
    margin: 0 0 20px 0;
    font-style: italic;
    position: relative;
  }

  .quote-text::before {
    content: '"';
    font-size: 3rem;
    color: rgba(255, 255, 255, 0.3);
    position: absolute;
    top: -10px;
    left: -20px;
  }

  .quote-text::after {
    content: '"';
    font-size: 3rem;
    color: rgba(255, 255, 255, 0.3);
    position: absolute;
    bottom: -30px;
    right: -20px;
  }

  .quote-attribution {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
  }

  .quote-author {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: 1px;
  }

  .quote-context {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .section-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 300;
    line-height: 0.9;
    color: #000;
    margin-bottom: 40px;
    letter-spacing: -0.02em;
  }

  .title-line {
    overflow: hidden;
    display: block;
  }

  .title-word {
    display: inline-block;
    transform: translateY(100%);
    opacity: 0;
  }

  .section-description {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: #666;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(30px);
  }

  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 40px;
    margin-bottom: 120px;
  }

  .service-item {
    position: relative;
    height: 500px;
    perspective: 1000px;
    opacity: 0;
    transform: translateY(80px);
  }

  .service-3d-container {
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .service-item:hover .service-3d-container {
    transform: rotateY(5deg) rotateX(2deg);
  }

  .service-card {
    position: relative;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 20px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0.05) 100%);
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  .service-item:hover .service-card::before {
    opacity: 1;
  }

  .service-hover-element {
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(0, 0, 0, 0.03) 0%, transparent 70%);
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transform: scale(0);
  }

  .service-item:hover .service-hover-element {
    opacity: 1;
    transform: scale(1);
  }

  .service-number {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #999;
    margin-bottom: 20px;
    letter-spacing: 1px;
  }

  .service-icon {
    width: 50px;
    height: 50px;
    margin-bottom: 30px;
    color: #000;
    transition: transform 0.4s ease;
  }

  .service-item:hover .service-icon {
    transform: scale(1.1) rotate(5deg);
  }

  .service-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 500;
    color: #000;
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  .service-description {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #666;
    line-height: 1.6;
    margin-bottom: 30px;
    flex: 1;
  }

  .service-features {
    list-style: none;
    padding: 0;
    margin: 0 0 30px;
  }

  .service-features li {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: #999;
    padding: 8px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    transition: color 0.3s ease;
  }

  .service-features li:last-child {
    border-bottom: none;
  }

  .service-item:hover .service-features li {
    color: #666;
  }

  /* CTA Section */
  .services-cta {
    text-align: center;
    padding: 60px 40px;
    background: rgba(0, 0, 0, 0.02);
    border-radius: 20px;
    backdrop-filter: blur(20px);
  }

  .cta-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    color: #000;
    margin-bottom: 15px;
    letter-spacing: -0.02em;
  }

  .cta-description {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: #666;
    margin-bottom: 25px;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: #000;
    border: none;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    border-radius: 50px;
    cursor: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .cta-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.6s ease;
  }

  .cta-button:hover::before {
    left: 100%;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

