---
// Concepts Showcase Component - Extracted for Performance
---

<section class="projects-showcase-section">
  <div class="animated-gradient"></div>
  
  <!-- Cinematic Title Section -->
  <div class="cinematic-title-container">
    <div class="title-background-text">CONCEPTS</div>
    <div class="main-title-wrapper">
      <div class="title-line">
        <span class="title-word">Our</span>
      </div>
      <div class="title-line">
        <span class="title-word highlight-word">CONCEPTS</span>
      </div>
    </div>
    <div class="subtitle-container">
      <p class="cinematic-subtitle">Explore our innovative design concepts</p>
    </div>
  </div>

  <div class="projects-container">
    <!-- Enhanced Navigation -->
    <div class="projects-navigation">
      <button class="nav-btn active" data-category="all">All Projects</button>
      <button class="nav-btn" data-category="e-commerce">E-commerce</button>
      <button class="nav-btn" data-category="saas">SaaS</button>
      <button class="nav-btn" data-category="portfolio">Portfolio</button>
      <button class="nav-btn" data-category="agency">Agency</button>
    </div>

    <!-- Project Display Grid -->
    <div class="project-display" id="projectDisplay">
      <!-- Projects will be loaded here -->
      <div class="project-card" data-category="e-commerce">
        <div class="project-preview">
          <img src="https://images.unsplash.com/photo-1472851294608-062f824d29cc?w=800&h=600&fit=crop" alt="E-commerce Concept" loading="lazy" />
          <div class="project-overlay">
            <div class="project-meta">
              <h3>Premium Store</h3>
              <p>E-commerce • Fashion • Luxury</p>
              <div class="conversion-rate">+340% CVR</div>
            </div>
          </div>
        </div>
      </div>

      <div class="project-card" data-category="saas">
        <div class="project-preview">
          <img src="https://images.unsplash.com/photo-1551650975-87deedd944c3?w=800&h=600&fit=crop" alt="SaaS Concept" loading="lazy" />
          <div class="project-overlay">
            <div class="project-meta">
              <h3>Analytics Pro</h3>
              <p>SaaS • Analytics • Dashboard</p>
              <div class="conversion-rate">+280% CVR</div>
            </div>
          </div>
        </div>
      </div>

      <div class="project-card" data-category="portfolio">
        <div class="project-preview">
          <img src="https://images.unsplash.com/photo-1467232004584-a241de8bcf5d?w=800&h=600&fit=crop" alt="Portfolio Concept" loading="lazy" />
          <div class="project-overlay">
            <div class="project-meta">
              <h3>Creative Studio</h3>
              <p>Portfolio • Design • Creative</p>
              <div class="conversion-rate">+450% CVR</div>
            </div>
          </div>
        </div>
      </div>

      <div class="project-card" data-category="agency">
        <div class="project-preview">
          <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&h=600&fit=crop" alt="Agency Concept" loading="lazy" />
          <div class="project-overlay">
            <div class="project-meta">
              <h3>Digital Agency</h3>
              <p>Agency • Marketing • Growth</p>
              <div class="conversion-rate">+390% CVR</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Projects Showcase Section */
  .projects-showcase-section {
    background: #ffffff;
    padding: 120px 0;
    position: relative;
    overflow: hidden;
  }

  .animated-gradient {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(45deg, transparent, rgba(0, 0, 0, 0.02), transparent);
    animation: gradientShift 20s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes gradientShift {
    0%, 100% { transform: translateX(-100%); }
    50% { transform: translateX(100%); }
  }

  .cinematic-title-container {
    text-align: center;
    margin-bottom: 80px;
    position: relative;
  }

  .title-background-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(4rem, 15vw, 12rem);
    font-weight: 900;
    color: rgba(0, 0, 0, 0.03);
    letter-spacing: -0.05em;
    pointer-events: none;
    z-index: 1;
    opacity: 0;
  }

  .main-title-wrapper {
    position: relative;
    z-index: 2;
  }

  .title-line {
    overflow: hidden;
    margin-bottom: 10px;
  }

  .title-word {
    display: inline-block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 600;
    color: #000000;
    letter-spacing: -0.02em;
    opacity: 0;
    transform: translateY(100%);
  }

  .highlight-word {
    background: linear-gradient(135deg, #000000 0%, #333333 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 800;
  }

  .subtitle-container {
    margin-top: 30px;
    opacity: 0;
    transform: translateY(30px);
  }

  .cinematic-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #666666;
    font-weight: 400;
    margin: 0;
  }

  .projects-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 60px;
  }

  .projects-navigation {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 60px;
    flex-wrap: wrap;
  }

  .nav-btn {
    padding: 12px 24px;
    background: transparent;
    border: 2px solid rgba(0, 0, 0, 0.1);
    border-radius: 50px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #666666;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .nav-btn:hover,
  .nav-btn.active {
    background: #000000;
    color: white;
    border-color: #000000;
    transform: translateY(-2px);
  }

  .project-display {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 40px;
  }

  .project-card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: white;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    opacity: 0;
    transform: translateY(30px);
  }

  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }

  .project-preview {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .project-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .project-preview img {
    transform: scale(1.05);
  }

  .project-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    padding: 40px 30px 30px;
    color: white;
    transform: translateY(20px);
    opacity: 0;
    transition: all 0.3s ease;
  }

  .project-card:hover .project-overlay {
    transform: translateY(0);
    opacity: 1;
  }

  .project-meta h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.4rem;
    font-weight: 600;
    margin: 0 0 8px 0;
    color: white;
  }

  .project-meta p {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 12px 0;
  }

  .conversion-rate {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 20px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: white;
    backdrop-filter: blur(10px);
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .projects-showcase-section {
      padding: 80px 0;
    }

    .projects-container {
      padding: 0 30px;
    }

    .cinematic-title-container {
      margin-bottom: 60px;
    }

    .projects-navigation {
      gap: 15px;
    }

    .nav-btn {
      padding: 10px 18px;
      font-size: 13px;
    }

    .project-display {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }

  @media (max-width: 480px) {
    .projects-container {
      padding: 0 20px;
    }

    .projects-navigation {
      gap: 10px;
    }

    .nav-btn {
      padding: 8px 16px;
      font-size: 12px;
    }
  }
</style>

<script>
  // Lightweight project showcase functionality
  function initProjectShowcase() {
    console.log('🎯 Initializing lightweight project showcase...');
    
    // Animate project cards on scroll
    const observerOptions = {
      threshold: 0.2,
      rootMargin: '0px 0px -50px 0px'
    };

    const projectObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            const element = entry.target as HTMLElement;
            element.style.opacity = '1';
            element.style.transform = 'translateY(0)';
          }, index * 100);
          projectObserver.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Observe all project cards
    document.querySelectorAll('.project-card').forEach(card => {
      projectObserver.observe(card);
    });

    // Simple category filtering
    const navBtns = document.querySelectorAll('.nav-btn');
    const projectCards = document.querySelectorAll('.project-card');

    navBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');
        
        // Update active button
        navBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        // Filter projects
        projectCards.forEach(card => {
          const element = card as HTMLElement;
          const cardCategory = card.getAttribute('data-category');
          if (category === 'all' || cardCategory === category) {
            element.style.display = 'block';
            element.style.opacity = '1';
            element.style.transform = 'translateY(0)';
          } else {
            element.style.display = 'none';
          }
        });
      });
    });

    console.log('✅ Lightweight project showcase ready');
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProjectShowcase);
  } else {
    initProjectShowcase();
  }
</script> 